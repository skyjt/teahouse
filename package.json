{
  "name": "pantry",
  "productName": "茶话间",
  "version": "0.5.0",
  "description": "茶话间（Pantry）—— 纯内网、基于 IP 的局域网即时通讯与文件传输工具",
  "private": true,
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "9.6.0"
  },
  "scripts": {
    "postinstall": "node node_modules/@electron/rebuild/lib/cli.js -o better-sqlite3",
    "rebuild:electron": "node node_modules/@electron/rebuild/lib/cli.js -f -o better-sqlite3",
    "dev": "electron-vite dev",
    "dev:2": "sh scripts/dev-clients-2.sh",
    "dev:3": "sh scripts/dev-clients-3.sh",
    "dev:client1": "sh scripts/dev-client-1.sh",
    "dev:client2": "sh scripts/dev-client-2.sh",
    "dev:client3": "sh scripts/dev-client-3.sh",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:db": "esbuild src/main/store/db-selftest.ts --bundle --platform=node --target=node16 --external:better-sqlite3 --outfile=out/db-selftest.cjs --log-level=warning && cross-env ELECTRON_RUN_AS_NODE=1 electron out/db-selftest.cjs",
    "smoke": "npm run build && cross-env PANTRY_SMOKE=1 electron .",
    "dist:win": "npm run build && cross-env NO_UPDATE_NOTIFIER=1 electron-builder --win --x64 --publish never",
    "dist:linux": "npm run build && cross-env NO_UPDATE_NOTIFIER=1 electron-builder --linux --x64 --publish never",
    "dist:mac": "npm run build && cross-env NO_UPDATE_NOTIFIER=1 electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.pantry.app",
    "productName": "茶话间",
    "electronVersion": "22.3.27",
    "asar": true,
    "asarUnpack": [
      "**/better_sqlite3.node"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "publish": null,
    "win": {
      "icon": "build/icons/pantry-logo-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "Pantry-${version}-win-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "Pantry-${version}-win-${arch}-portable.${ext}"
    },
    "linux": {
      "icon": "build/icons/pantry-logo-icon.png",
      "maintainer": "Pantry Maintainers <pantry-maintainers@example.invalid>",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network",
      "artifactName": "Pantry-${version}-${os}-${arch}.${ext}"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1"
      ]
    },
    "mac": {
      "icon": "build/icons/pantry-logo-icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Pantry-${version}-${os}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "3.6.0",
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "16.18.119",
    "@vitejs/plugin-vue": "5.2.1",
    "cross-env": "7.0.3",
    "electron": "22.3.27",
    "electron-builder": "24.13.3",
    "electron-vite": "2.3.0",
    "pinia": "2.2.6",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.8",
    "vue": "3.5.13",
    "vue-tsc": "2.1.10"
  }
}
